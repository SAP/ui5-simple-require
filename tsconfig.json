{
  "compilerOptions": {
    "module": "es2015",
    "target": "esnext",
    "lib": ["DOM", "ESNext"],
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "rootDir": "./"
  }
}
