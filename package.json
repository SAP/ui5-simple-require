  "license": "ISC",
  "devDependencies": {
    "chai": "^6.2.2",
    "eslint": "^10.4.0",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1"
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
