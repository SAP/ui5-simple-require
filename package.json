{
  "name": "ui5-simple-require",
  "version": "2.0.1",
  "description": "Import UI5 modules into NodeJS applications, allowing isolation of UI5 components and injection of dependencies to create an isolated test environment",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "test": "mocha test/*Test.js",
    "coverage": "nyc npm run test",
    "test:debug": "mocha --inspect-brk test/*Test.js",
    "testwatcher": "mocha test/*Test.js --colors --recursive --watch"
  },
  "keywords": [
    "mocha",
    "ui5",
    "sapui5",
    "openui5",
    "unit test",
    "TDD"
  ],
  "homepage": "https://github.com/SAP/ui5-simple-require",
